---
const pages = [
  { href: '/', label: '关于' },
  { href: '/blog', label: 'Blog' },
  { href: '/projects', label: '项目' },
  { href: '/games', label: '游戏' },
];
const currentPath = Astro.url.pathname;
---

<nav class="sticky top-0 z-50 flex items-center justify-between px-8 py-5 backdrop-blur-md bg-bg/75 border-b border-border">
  <a href="/" class="font-serif text-xl font-bold text-white tracking-wide no-underline hover:opacity-80 transition-opacity">
    魏乐康
  </a>
  <div class="flex gap-8">
    {
      pages.map((p) => {
        const isActive = currentPath === p.href || (p.href !== '/' && currentPath.startsWith(p.href));
        return (
          <a
            href={p.href}
            class={`text-[13px] font-medium tracking-wider no-underline transition-colors ${
              isActive
                ? 'text-white border-b-2 border-accent pb-1'
                : 'text-text-dim hover:text-white'
            }`}
          >
            {p.label}
          </a>
        );
      })
    }
  </div>
</nav>
