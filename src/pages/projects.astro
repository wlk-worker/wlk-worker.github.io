---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="项目" description="魏乐康的项目">
  <div class="mb-16">
    <h1 class="font-serif text-5xl md:text-6xl font-bold text-white tracking-tight leading-tight mb-3" style="text-shadow: 0 0 80px rgba(168,139,250,0.25);">
      项目
    </h1>
    <p class="text-base text-text-dim font-light">做过的和正在做的东西。</p>
  </div>

  <div class="text-center py-20">
    <p class="text-text-dim text-sm mb-4">还没有项目，但会有的。</p>
    <p class="text-text-faint text-xs">想法正在从「想做」变成「在做」。</p>
  </div>
</BaseLayout>
