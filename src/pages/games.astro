---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="游戏" description="一些小游戏">
  <div class="mb-16">
    <h1 class="font-serif text-5xl md:text-6xl font-bold text-white tracking-tight leading-tight mb-3" style="text-shadow: 0 0 80px rgba(168,139,250,0.25);">
      游戏
    </h1>
    <p class="text-base text-text-dim font-light">还没想好放什么游戏，先占个位置。</p>
  </div>

  <div class="text-center py-20">
    <p class="text-4xl mb-4">🕹️</p>
    <p class="text-text-dim text-sm">敬请期待</p>
  </div>
</BaseLayout>
